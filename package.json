{
  "name": "competitor-research-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/prepare-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --test scripts/*.test.mjs",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build",
    "test:e2e": "playwright test",
    "cron:scheduled-reruns": "node scripts/invoke-scheduled-reruns.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@plausible-analytics/tracker": "^0.4.5",
    "@stripe/stripe-js": "^4.0.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "^16.2.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.14.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "playwright": "^1.60.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
