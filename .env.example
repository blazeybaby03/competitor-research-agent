# Supabase — supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe — stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Starter + Pro price IDs (used by the billing page and checkout route)
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...

# Plan limits — safe defaults match the Phase 6 pricing decision brief.
REPORT_LIMIT_STARTER=10
REPORT_LIMIT_PRO=100
COMPETITOR_LIMIT_FREE=3
COMPETITOR_LIMIT_STARTER=3
COMPETITOR_LIMIT_PRO=5

# ScraperAPI — scraperapi.com → dashboard
SCRAPERAPI_KEY=your_scraperapi_key

# Anthropic — console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model (default: claude-haiku-4-5-20251001)
AI_MODEL=claude-haiku-4-5-20251001

# App URL — set to the active production app host. Do not set this to Supabase.
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Resend — transactional email for guest report drip sequences (resend.com → API keys)
RESEND_API_KEY=re_...

# Public support email shown on billing pages
NEXT_PUBLIC_SUPPORT_EMAIL=info@competeiq.pro

# Secret for the scheduled re-run cron (Stage 4). Railway Cron or
# another scheduler must send this as a Bearer token. The route fails closed if unset.
CRON_SECRET=Vm5TXE7wWWXQRVMX

# Optional absolute URL for the Railway cron service. If unset, the cron invoker
# calls NEXT_PUBLIC_APP_URL + /api/cron/scheduled-reruns.
SCHEDULED_RERUN_URL=https://your-domain.com/api/cron/scheduled-reruns
